# Conexión a PostgreSQL (Railway la inyecta automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/database

# Clave secreta para firmar los JWT (cámbiala por una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-una-clave-secreta-muy-larga

# Puerto del servidor (Railway lo inyecta automáticamente)
PORT=3000
